# Fixfy Trade Portal — environment
# This app reuses the SAME Supabase database/structure as Fixfy OS (master-os).
# Point these at the same Supabase project as master-os.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (RLS bypass) — Stripe webhook + billing routes. Never expose to the client.
SERVICE_ROLE_KEY=

# Stripe (use LIVE keys in production; test keys for staging)
STRIPE_SECRET_KEY=
# The portal's OWN webhook signing secret (create an endpoint at /api/stripe/webhook) —
# NOT the master-os one.
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring Price id for the £99/mo "Fixfy Pro" plan. Create the Product+Price in Stripe,
# then paste the price id here. See scripts/create-stripe-price.mjs.
STRIPE_PRICE_FIXFY_PRO=

# Resend — partner sign-in OTP emails. FROM must be on a verified domain in production.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Mapbox — job-location map (My jobs → Map). Same token as master-os.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Master OS — server-only. Required for Available jobs → Accept job (delegates to OS).
# Must match INTERNAL_SYNC_SECRET on master-os (production: https://app.getfixfy.com).
MASTER_OS_BASE_URL=
INTERNAL_SYNC_SECRET=
